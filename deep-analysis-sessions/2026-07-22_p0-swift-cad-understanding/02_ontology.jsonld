  "@graph": [
    {
      "@id":"ea:p0/T001","@type":"Topic","title":"Three-repository local integration state",
      "content":"RupaKit resolves sibling swift-CAD by local path; swift-CAD resolves sibling swift-OpenUSD, so integration state is a revision tuple rather than one repository commit.",
      "epistemicStatus":"verified","confidence":0.99
    },
    {
      "@id":"ea:p0/E001","@type":"Evidence","title":"Four contract generations and large WIP",
      "content":"G0 PersistentName, G1 SubshapeID, G2 StableSubshapeReference/exact architecture, and G3 certified-geometry WIP are layered. Current swift-CAD has 248 modified, 11 deleted, and 186 untracked entries.",
      "epistemicStatus":"verified","confidence":0.99,
      "source":"Git history, status, diff statistics, source inspection","sourceUrl":"local://swift-CAD","reliability":0.99
    },
    {
      "@id":"ea:p0/E002","@type":"Evidence","title":"Current and historical test outcomes",
      "content":"Current CADGeometry is 224/242 pass and CADKernel is 416/464 pass. Pure a875eeb facade builds but CADGeometry has 9 unique failing tests.",
      "epistemicStatus":"verified","confidence":0.99,
      "source":"xcodebuild and xcresult summaries","sourceUrl":"local://xcodebuild/swift-cad","reliability":0.99
    },
    {
      "@id":"ea:p0/E003","@type":"Evidence","title":"Buildable Rupa-compatible revision tuple",
      "content":"Rupa 4d90a4b with swift-CAD 35ffd6e and swift-OpenUSD 998e505 builds the full RupaKit package. The generated topology selection round-trip test executed once and passed once.",
      "epistemicStatus":"verified","confidence":0.99,
      "source":"Isolated Git worktrees, xcodebuild, xcresult totalTestCount","sourceUrl":"local://xcodebuild/rupa-compatible-tuple","reliability":0.99
    },
    {
      "@id":"ea:p0/E004","@type":"Evidence","title":"Authoritative completion contracts reject preservation as completion",
      "content":"Rupa requires implementation, tests, review, fixes, and re-verification across the named conformance scope. Swift-CAD requires all public contracts supported and G0 through G7 passing on one revision; local builds and bounded envelopes earn no completion credit.",
      "epistemicStatus":"verified","confidence":0.99,
      "source":"Rupa GOAL_STATEMENT, CAD_QUALITY_MILESTONES, IMPLEMENTATION_STATUS, and Swift-CAD ROADMAP at the WIP checkpoint","sourceUrl":"local://goal-authority","reliability":0.99
    },
    {
      "@id":"ea:p0/I001","@type":"Insight","title":"The blocker is overlapping contract generations",
      "content":"Committing or fixing the current tree as one unit would conflate a recoverable Rupa contract, two selection migrations, and several unfinished exact-kernel research clusters.",
      "epistemicStatus":"evidenced","confidence":0.97,
      "derivedFrom":["ea:p0/E001","ea:p0/E002","ea:p0/E003"],
      "rationale":"The version boundaries produce different compile behavior, test behavior, and persistence identities; the working diff also has untracked dependencies that cannot be omitted.",
      "supportsClaim":["ea:p0/I002"]
    },
    {
      "@id":"ea:p0/Q001","@type":"Question","title":"What should P0 freeze?",
      "content":"Should P0 treat the current WIP as the integration baseline, or preserve it separately from the last verified Rupa-compatible tuple?",
      "epistemicStatus":"answered","confidence":0.99,"questionStatus":"answered"
    },
    {
      "@id":"ea:p0/T002","@type":"Topic","title":"Separate preservation from integration",
      "content":"Preserve G3 as an explicitly red archival checkpoint, define the G0 three-repository tuple as the Rupa integration baseline, and extract G1-G3 in eight dependency-ordered atomic clusters.",
      "epistemicStatus":"recommended","confidence":0.96,
      "primaryEvidence":["ea:p0/E001","ea:p0/E002","ea:p0/E003"]
    },
    {
      "@id":"ea:p0/I002","@type":"Insight","title":"Recoverability is a prerequisite, not P0 completion",
      "content":"Checkpointing and a reproducible legacy tuple protect the work but do not finish P0. Completion requires the forward stable-subshape exact-kernel contract to work through Rupa's source, command, evaluation, selection, UI, Automation, Agent, diagnostic, and verification paths under the authoritative same-revision gates.",
      "epistemicStatus":"evidenced","confidence":0.97,
      "derivedFrom":["ea:p0/I001","ea:p0/T002","ea:p0/E004"],
      "rationale":"The preservation conditions restore a safe base, while the normative goal documents explicitly deny completion credit to local builds, partial capability envelopes, and checkpoints with open regressions.",
      "primaryEvidence":["ea:p0/E001","ea:p0/E002","ea:p0/E003","ea:p0/E004"],
      "sourceTopics":["ea:p0/T001","ea:p0/T002"],
      "visualEvidenceRequirement":{"required":true,"charts":["version strata","test matrix","atomic clusters","exit criteria"]},
      "synthesis":{"claimRole":"final-claim"}
    }
  ]
