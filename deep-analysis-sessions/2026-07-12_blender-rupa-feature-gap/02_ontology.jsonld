      "@id": "ea:session/blender-rupa-feature-gap/insight/I001",
      "@type": "Insight",
      "title": "Shared foundations dominate the gap",
      "content": "The highest-leverage missing work is editable mesh/attributes, modifier/procedural evaluation, assets/references, plugins, and GPU scene display rather than isolated leaf commands.",
      "epistemicStatus": "Evidenced",
      "confidence": 0.93,
      "derivedFrom": [
