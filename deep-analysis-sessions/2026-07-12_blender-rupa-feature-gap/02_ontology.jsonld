  "@graph": [
    {
      "@id": "ea:session/blender-rupa-feature-gap/topic/T001",
      "@type": "Topic",
      "title": "Comparison scope",
      "content": "Blender 5.1 operation families are compared with end-to-end Rupa production capabilities, excluding documentation-only aliases and individual parameter pages.",
      "epistemicStatus": "Verified",
      "confidence": 0.99,
      "visualEvidenceRequirement": {
        "evidencePattern": "coverage matrix",
        "requiredChartType": "matrix"
      }
    },
    {
      "@id": "ea:session/blender-rupa-feature-gap/topic/T002",
      "@type": "Topic",
      "title": "Rupa CAD and Agent baseline",
      "content": "Rupa has a substantial exact CAD, selection, drawing, scene, transaction, CLI, and Agent baseline that must not be confused with Blender-wide DCC parity.",
      "epistemicStatus": "Verified",
      "confidence": 0.98
    },
    {
      "@id": "ea:session/blender-rupa-feature-gap/topic/T003",
      "@type": "Topic",
      "title": "Interface and editor gap",
      "content": "Rupa lacks Blender configurable workspaces, editor-area system, broad mode framework, and most specialized editors.",
      "epistemicStatus": "Verified",
      "confidence": 0.97
    },
    {
      "@id": "ea:session/blender-rupa-feature-gap/topic/T004",
      "@type": "Topic",
      "title": "Scene and object gap",
      "content": "Rupa scene hierarchy and components do not cover multiple scenes, view layers, collections, constraints, or Blender object types.",
      "epistemicStatus": "Verified",
      "confidence": 0.97
    },
    {
      "@id": "ea:session/blender-rupa-feature-gap/topic/T005",
      "@type": "Topic",
      "title": "Polygon mesh foundation gap",
      "content": "Rupa lacks a complete source-owned mutable polygon mesh, attribute domains, and general element operations.",
      "epistemicStatus": "Verified",
      "confidence": 0.99
    },
    {
      "@id": "ea:session/blender-rupa-feature-gap/topic/T006",
      "@type": "Topic",
      "title": "Curve and surface breadth gap",
      "content": "Rupa has strong CAD subsets but not Blender general curve, hair curve, surface, metaball, text, point cloud, and volume systems.",
      "epistemicStatus": "Verified",
      "confidence": 0.96
    },
    {
      "@id": "ea:session/blender-rupa-feature-gap/topic/T007",
      "@type": "Topic",
      "title": "Modifier and procedural graph gap",
      "content": "Rupa lacks a generic modifier stack and Geometry Nodes runtime, including fields, attributes, zones, baking, and node-authored tools.",
      "epistemicStatus": "Verified",
      "confidence": 0.99
    },
    {
      "@id": "ea:session/blender-rupa-feature-gap/topic/T008",
      "@type": "Topic",
      "title": "Sculpt, paint, and Grease Pencil gap",
      "content": "Sculpting, texture/vertex/weight paint, grooming, and Grease Pencil are absent.",
      "epistemicStatus": "Verified",
      "confidence": 0.99
    },
    {
      "@id": "ea:session/blender-rupa-feature-gap/topic/T009",
      "@type": "Topic",
      "title": "Animation and rigging gap",
      "content": "Keyframes, F-curves, actions, NLA, drivers, armatures, constraints, shape keys, and motion paths are absent.",
      "epistemicStatus": "Verified",
      "confidence": 0.99
    },
    {
      "@id": "ea:session/blender-rupa-feature-gap/topic/T010",
      "@type": "Topic",
      "title": "Physics and simulation gap",
      "content": "Rigid body, cloth, soft body, fluids, particles, dynamic paint, force fields, and baking are absent.",
      "epistemicStatus": "Verified",
      "confidence": 0.99
    },
    {
      "@id": "ea:session/blender-rupa-feature-gap/topic/T011",
      "@type": "Topic",
      "title": "Rendering and media gap",
      "content": "Rupa has CAD display and material metadata but no production renderer, shader graph, compositor, tracking, video, or audio pipeline.",
      "epistemicStatus": "Verified",
      "confidence": 0.98
    },
    {
      "@id": "ea:session/blender-rupa-feature-gap/topic/T012",
      "@type": "Topic",
      "title": "Asset, file, and production pipeline gap",
      "content": "Rupa lacks data-block libraries, append/link, overrides, asset catalogs, broad DCC exchange semantics, autosave, and recovery.",
      "epistemicStatus": "Verified",
      "confidence": 0.97
    },
    {
      "@id": "ea:session/blender-rupa-feature-gap/topic/T013",
      "@type": "Topic",
      "title": "Scripting and Agent integration gap",
      "content": "Typed Automation is substantial, while embedded scripting, runtime extensions, MCP, and compact procedural Agent programs are absent.",
      "epistemicStatus": "Verified",
      "confidence": 0.98
    },
    {
      "@id": "ea:session/blender-rupa-feature-gap/topic/T014",
      "@type": "Topic",
      "title": "Responsibility boundary",
      "content": "Exact CAD remains in Swift-CAD; mesh/procedural foundations, DCC systems, domain semantics, and adapters require separate higher modules.",
      "epistemicStatus": "Verified",
      "confidence": 0.95
    },
    {
      "@id": "ea:session/blender-rupa-feature-gap/topic/T015",
      "@type": "Topic",
      "title": "Dependency-ordered delivery",
      "content": "Foundational mesh, modifier, asset, plugin, and adapter contracts must precede leaf Blender feature imitation.",
      "epistemicStatus": "Verified",
      "confidence": 0.95,
      "visualEvidenceRequirement": {
        "evidencePattern": "dependency sequence",
        "requiredChartType": "roadmap"
      }
    },
    {
      "@id": "ea:session/blender-rupa-feature-gap/evidence/E001",
      "@type": "Evidence",
      "title": "Blender 5.1 official taxonomy",
      "content": "The official manual defines editors, scenes, modeling, sculpting, Grease Pencil, animation, physics, rendering, compositing, tracking, video, files, add-ons, and scripting as integrated product areas.",
      "epistemicStatus": "Verified",
      "confidence": 0.98,
      "source": "Blender 5.1 Manual",
      "sourceUrl": "https://docs.blender.org/manual/en/latest/",
      "reliability": 0.98,
